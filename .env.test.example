# Test Credentials for E2E Tests
# Copy this file to .env.local and fill in the values

# ============================================
# E2E Test Credentials
# ============================================
# Create a test user in your Supabase instance
# Then add the credentials below

TEST_EMAIL=rang1kuwr@hotmail.com
TEST_PASSWORD=Test1234!

# ============================================
# Supabase (for seed data)
# ============================================
# These are only needed if you want to run seed-data.sql
# Use your development Supabase credentials

# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_DB_PASSWORD=your_db_password (for direct DB access)

# ============================================
# Usage
# ============================================
# 1. Copy this file: cp .env.test.example .env.local
# 2. Fill in your test user credentials
# 3. Run seed-data.sql in Supabase SQL Editor
# 4. Run tests: npm run test:e2e
