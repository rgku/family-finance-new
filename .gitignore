# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase temp files
supabase/.temp/
supabase/**/.temp/

# Sensitive SQL files (migrations with secrets)
# These should be managed separately or encrypted with SOPS
# supabase/migrations/*_with_secrets.sql

# Security: Don't commit files containing API keys or secrets
# *.secret
# *.private
# credentials.json
# service-account.json

# Scripts de debug com keys
scripts/check-data.js
scripts/check-user-data.js

