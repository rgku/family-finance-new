# ============================================
# Environment Variables - COPY TO .env.local
# ============================================

# Supabase (obrigatório para desenvolvimento local)
NEXT_PUBLIC_SUPABASE_URL=https://pqsjmavtkcrnorjemasq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# API KEYS - NÃO COMMITAR NO GIT!
# ============================================

# Groq API (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_key_here

# Cohere API (https://dashboard.cohere.com/)
COHERE_API_KEY=your_cohere_key_here

# Supabase Service Role (https://app.supabase.com/settings/api)
# ⚠️ NUNCA usar em código do cliente!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# PUSH NOTIFICATIONS
# ============================================

# VAPID Keys (gerar com: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# OneSignal (https://onesignal.com)
NEXT_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id_here
ONESIGNAL_REST_API_KEY=your_onesignal_rest_key_here

# ============================================
# SERVER CONFIG
# ============================================

HOST=0.0.0.0
PORT=3000